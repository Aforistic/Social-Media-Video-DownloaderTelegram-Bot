
# Your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram channel ID (e.g. -1001234567890)
# How to get it: add @userinfobot to your channel as admin, it will show the channel ID
# Channel IDs always start with -100
ADMIN_ID=-1001234567890

# Your personal Telegram user ID (for admin commands like /stats /users /broadcast)
# Get it by messaging @userinfobot directly
OWNER_ID=123456789
